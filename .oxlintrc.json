{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "node": true,
    "es2023": true
  },
  "ignorePatterns": ["dist", "node_modules"],
  "rules": {
    "no-unused-vars": "error",
    "eqeqeq": "error"
  }
}
